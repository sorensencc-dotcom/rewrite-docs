# CIC Update-Monitor Environment Configuration
# Copy to .env and fill in your values

# ============================================================================
# GitHub
# ============================================================================
# Personal access token for GitHub API (https://github.com/settings/tokens)
# Scopes needed: repo (read-only)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
# Strong password for PostgreSQL admin user
DB_PASSWORD=your_secure_password_here_min_16_chars

# ============================================================================
# Docker Registry (for auto-builds)
# ============================================================================
# Docker Hub or private registry
REGISTRY_URL=docker.io
REGISTRY_USER=your_docker_username
REGISTRY_PASSWORD=your_docker_token_or_password

# ============================================================================
# Services (typically don't need to change)
# ============================================================================
UPDATE_MONITOR_URL=http://update-monitor:8000
HARVESTER_URL=http://harvester:4000
ROADMAP_URL=http://roadmap-service:3000
CODEFLOW_ANALYZER_URL=http://codeflow-analyzer:8080

# Phase 6: Autonomous Cross-Orchestration (Redis queue)
REDIS_URL=redis://redis-cic:6379

# CIC Governance Token (required for AutonomyGovernanceBridge → cic-governance:3113)
# Generate with: openssl rand -hex 32
CIC_GOVERNANCE_TOKEN=your_cic_governance_token_here

# ============================================================================
# Observability
# ============================================================================
# Grafana admin password
GRAFANA_PASSWORD=admin_change_this

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# ============================================================================
# Optional: Advanced Configuration
# ============================================================================
# Update Monitor polling interval (minutes)
UPDATE_MONITOR_POLL_INTERVAL_MINUTES=5

# Number of Update Monitor replicas (for scaling)
UPDATE_MONITOR_REPLICAS=1

# Enable debug mode (more verbose logging)
DEBUG=false
