FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache git curl jq bash

# Copy performance-store service
COPY performance-store.js ./performance-store.js

ENV NODE_ENV=production
ENV LOG_LEVEL=info
ENV PORT=3105

EXPOSE 3105

HEALTHCHECK --interval=10s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:3105/health || exit 1

# Run performance-store service
CMD ["node", "performance-store.js"]
