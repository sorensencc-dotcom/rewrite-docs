# CIC Agent Runtime Configuration

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cic_agents

# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_WEBHOOK_SECRET=dev-secret-change-in-production

# Docker
DOCKER_SOCKET=/var/run/docker.sock
SANDBOX_IMAGE=cic-sandbox:latest

# Agent Runtime
LOG_LEVEL=info
WEBHOOK_PORT=3001
NODE_ENV=development

# Optional: Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=cic-agent-pr-reviewer
