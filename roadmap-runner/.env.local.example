# Roadmap Runner Environment
# Copy to .env.local and fill in actual values

# Docker registry (e.g., docker.io, ECR URL, etc.)
REGISTRY=docker.io

# Rewrite Labs services
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
OUTREACH_API_KEY=

# Shared services
QDRANT_URL=http://qdrant:6333

# Observability
LOG_LEVEL=info
METRICS_PUSH_GATEWAY=http://prometheus-pushgateway:9091

# Optional: Slack webhook for failures
SLACK_WEBHOOK_URL=
