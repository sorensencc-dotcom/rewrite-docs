{
  "title": "Phase C - Resilience Metrics",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "provider",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(resilience_avg_latency_ms, provider)",
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Avg Latency (ms)",
      "targets": [
        {
          "expr": "resilience_avg_latency_ms{provider=\"$provider\"}"
        }
      ],
      "id": 1,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Failure Rate",
      "targets": [
        {
          "expr": "resilience_failure_rate{provider=\"$provider\"}"
        }
      ],
      "id": 2,
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Rate Limit Rejection Rate",
      "targets": [
        {
          "expr": "resilience_rate_limit_rejection_rate{provider=\"$provider\"}"
        }
      ],
      "id": 3,
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "stat",
      "title": "Circuit Breaker State",
      "targets": [
        {
          "expr": "resilience_circuit_breaker_state{provider=\"$provider\"}"
        }
      ],
      "id": 4,
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      }
    },
    {
      "type": "timeseries",
      "title": "Total Requests",
      "targets": [
        {
          "expr": "resilience_summary_total_requests"
        }
      ],
      "id": 5,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Total Errors",
      "targets": [
        {
          "expr": "resilience_summary_total_errors"
        }
      ],
      "id": 6,
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "Error Ratio",
      "targets": [
        {
          "expr": "resilience_summary_total_errors / resilience_summary_total_requests"
        }
      ],
      "id": 7,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      }
    }
  ]
}
