{
  "name": "cic-agent-runtime",
  "version": "0.2.0",
  "description": "CIC Agent Runtime with Postgres, Docker, and Node.js orchestration",
  "type": "module",
  "main": "cic-runtime/defineAgent.ts",
  "bin": {
    "cic-report": "./dist/scripts/cic-report.js"
  },
  "scripts": {
    "start": "tsx cic-runtime/example-entrypoint.ts",
    "start:maal": "tsx cic-runtime/bootstrap-maal.ts",
    "start:adapter-gateway": "tsx src/server/adapterGatewayAPI.ts",
    "test": "jest && tsx docs-manager/cli.ts audit",
    "test:snapshot": "playwright test",
    "test:snapshot:headed": "playwright test --headed",
    "test:snapshot:debug": "playwright test --debug",
    "dev": "tsx watch cic-runtime/example-entrypoint.ts",
    "build": "tsc && tsx docs-manager/cli.ts sync",
    "lint": "tsc --noEmit",
    "cic-ui": "node cic-ui/index.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "console-api:dev": "tsx src/server/consoleAPI.ts",
    "agents-api:dev": "tsx src/server/agentsAPI.ts",
    "console-v3:test": "playwright test ConsoleV3.a11y.test.ts",
    "console-v3:test:headed": "playwright test ConsoleV3.a11y.test.ts --headed",
    "canary-gates": "tsx scripts/canary-gates.ts",
    "canary-gates:A": "tsx scripts/canary-gates.ts A",
    "canary-gates:B": "tsx scripts/canary-gates.ts B",
    "canary-gates:C": "tsx scripts/canary-gates.ts C",
    "fire-drills": "tsx scripts/fire-drills.ts",
    "docs:audit": "tsx docs-manager/cli.ts audit",
    "docs:sync": "tsx docs-manager/cli.ts sync",
    "docs:drift": "tsx docs-manager/cli.ts drift",
    "docs:consolidate": "tsx docs-manager/cli.ts consolidate",
    "docs:refresh": "tsx docs-manager/cli.ts refresh",
    "release": "npm run build && npm run docs:refresh && npm version patch"
  },
  "dependencies": {
    "dockerode": "^4.0.0",
    "express": "^4.18.0",
    "js-yaml": "^4.1.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.0",
    "pg": "^8.11.0",
    "pino": "^8.16.0",
    "pino-pretty": "^10.2.0",
    "prom-client": "^15.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@storybook/addon-docs": "^8.0.0",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-webpack5": "^8.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dockerode": "^3.3.21",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.8",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^10.0.0",
    "@visx/curve": "^3.3.0",
    "@visx/scale": "^3.3.0",
    "@visx/shape": "^3.3.0",
    "commander": "^12.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "onnxruntime-node": "^1.18.0",
    "simple-git": "^3.36.0",
    "storybook": "^8.0.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "whatwg-fetch": "^3.6.20"
  }
}
