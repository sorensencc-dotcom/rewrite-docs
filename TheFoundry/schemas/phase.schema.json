{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Phase Configuration Schema",
  "description": "Schema for phase.yaml files",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(PHASE|RL)-[A-Z0-9.]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "container": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "env": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["exit_code", "metric", "output"]
          }
        },
        "required": ["type"]
      }
    }
  },
  "required": ["id", "title", "container", "command"]
}
